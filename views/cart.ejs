<%- include('./partials/header') %>

<div class="w-full min-h-screen flex items-start px-20 py-20 gap-10">

    <!-- LEFT: ALL CART PRODUCTS -->
    <div class="w-[40%] flex flex-col gap-6">

        <% let total = 0; %>

        <% cart.forEach(function(item){ %>

            <div class="w-full rounded-xl overflow-hidden border shadow-sm bg-white">

                <!-- IMAGE -->
                <div class="w-full h-64 flex items-center justify-center bg-gray-100">
                    <img 
                        src="data:image/png;base64,<%= item.image.toString('base64') %>" 
                        class="max-h-full max-w-full object-contain"
                    />
                </div>

                <!-- CONTENT -->
                <div class="w-full flex justify-between px-5 py-4">
                    <h3 class="text-lg font-semibold"><%= item.name %></h3>
                </div>

                <!-- PRICE -->
                <div class="flex items-center justify-between px-5 pb-4">
                    <h4>Price</h4>
                    <h2>₹ <%= item.price %></h2>
                </div>

            </div>

            <% total += item.price; %>  <!-- ✅ IMPORTANT -->

        <% }) %>

    </div>

    <!-- RIGHT: TOTAL SECTION -->
    <div class="w-[60%]">
        <h3 class="text-xl">Price Breakdown</h3>

        <div class="px-10 mt-5">
            <div class="flex mt-2">
                <h4 class="w-1/3">Total MRP</h4>
                <h4>₹ <%= total %></h4>
            </div>

            <div class="flex mt-2">
                <h4 class="w-1/3">Platform Fee</h4>
                <h4>₹ 20</h4>
            </div>

            <div class="flex mt-2">
                <h4 class="w-1/3">Shipping Fee</h4>
                <h4>FREE</h4>
            </div>
        </div>

        <div class="w-full h-[1px] bg-black mt-10"></div>

        <div class="flex mt-5">
            <h3 class="w-1/3 text-xl">Total Amount</h3>
            <h3 class="font-semibold text-xl text-green-600">
                ₹ <%= total + 20 %>
            </h3>
        </div>
    </div>

</div>

<%- include('./partials/footer') %>